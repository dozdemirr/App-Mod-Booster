@page
@model CategoriesModel
@{
    ViewData["Title"] = "Categories";
    ViewData["ActivePage"] = "Categories";
}

<div class="page-header">
    <h1>Expense Categories</h1>
    <p>View and manage expense categories</p>
</div>

<div class="card">
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Category Name</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Categories.Any())
            {
                <tr><td colspan="3"><div class="empty-state"><p>No categories found</p></div></td></tr>
            }
            @foreach (var cat in Model.Categories)
            {
                <tr>
                    <td>#@cat.CategoryId</td>
                    <td>@cat.CategoryName</td>
                    <td><span class="badge @(cat.IsActive ? "badge-active" : "badge-inactive")">@(cat.IsActive ? "Active" : "Inactive")</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>
