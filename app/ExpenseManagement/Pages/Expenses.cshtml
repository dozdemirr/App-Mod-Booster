@page
@model ExpensesModel
@{
    ViewData["Title"] = "Expenses";
    ViewData["ActivePage"] = "Expenses";
}

<div class="page-header">
    <h1>Expenses</h1>
    <p>Manage and review all expense claims</p>
</div>

<div class="card">
    <div class="card-header">
        <div class="filter-bar" style="margin-bottom:0">
            <form method="get" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                <select name="filter" class="form-control" style="width:auto" onchange="this.form.submit()">
                    <option value="all" selected="@(Model.Filter == "all")">All Expenses</option>
                    <option value="Draft" selected="@(Model.Filter == "Draft")">Draft</option>
                    <option value="Submitted" selected="@(Model.Filter == "Submitted")">Submitted</option>
                    <option value="Approved" selected="@(Model.Filter == "Approved")">Approved</option>
                    <option value="Rejected" selected="@(Model.Filter == "Rejected")">Rejected</option>
                </select>
            </form>
        </div>
        <button class="btn btn-primary btn-sm" onclick="document.getElementById('addExpenseModal').classList.add('active')">+ Add Expense</button>
    </div>
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Employee</th>
                <th>Category</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Expenses.Any())
            {
                <tr><td colspan="7"><div class="empty-state"><p>No expenses found</p></div></td></tr>
            }
            @foreach (var expense in Model.Expenses)
            {
                <tr>
                    <td>#@expense.ExpenseId</td>
                    <td>@expense.UserName</td>
                    <td>@expense.CategoryName</td>
                    <td class="amount">£@expense.AmountGBP.ToString("N2")</td>
                    <td><span class="badge badge-@expense.StatusName.ToLower()">@expense.StatusName</span></td>
                    <td>@expense.ExpenseDate.ToString("dd MMM yyyy")</td>
                    <td>
                        <div class="actions-cell">
                            <a href="/ExpenseDetail?id=@expense.ExpenseId" class="btn btn-secondary btn-xs">View</a>
                            @if (expense.StatusName == "Draft")
                            {
                                <form method="post" asp-page-handler="Submit" style="display:inline">
                                    <input type="hidden" name="id" value="@expense.ExpenseId" />
                                    <button type="submit" class="btn btn-primary btn-xs">Submit</button>
                                </form>
                            }
                            @if (expense.StatusName == "Submitted")
                            {
                                <form method="post" asp-page-handler="Approve" style="display:inline">
                                    <input type="hidden" name="id" value="@expense.ExpenseId" />
                                    <input type="hidden" name="reviewedBy" value="1" />
                                    <button type="submit" class="btn btn-success btn-xs">Approve</button>
                                </form>
                                <form method="post" asp-page-handler="Reject" style="display:inline">
                                    <input type="hidden" name="id" value="@expense.ExpenseId" />
                                    <input type="hidden" name="reviewedBy" value="1" />
                                    <button type="submit" class="btn btn-danger btn-xs">Reject</button>
                                </form>
                            }
                            @if (expense.StatusName == "Draft")
                            {
                                <form method="post" asp-page-handler="Delete" style="display:inline" onsubmit="return confirm('Delete this expense?')">
                                    <input type="hidden" name="id" value="@expense.ExpenseId" />
                                    <button type="submit" class="btn btn-danger btn-xs">Delete</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal-overlay" id="addExpenseModal">
    <div class="modal">
        <div class="modal-header">
            <h3>Add New Expense</h3>
            <button class="modal-close" onclick="document.getElementById('addExpenseModal').classList.remove('active')">×</button>
        </div>
        <form method="post" asp-page-handler="Create">
            <div class="modal-body">
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Employee</label>
                        <select name="userId" class="form-control" required>
                            @foreach (var user in Model.Users)
                            {
                                <option value="@user.UserId">@user.UserName</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Category</label>
                        <select name="categoryId" class="form-control" required>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.CategoryId">@cat.CategoryName</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Amount (£)</label>
                        <input type="number" name="amountGBP" class="form-control" step="0.01" min="0.01" required placeholder="0.00" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Date</label>
                        <input type="date" name="expenseDate" class="form-control" required value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <input type="text" name="description" class="form-control" required placeholder="What was this expense for?" />
                </div>
                <div class="form-group">
                    <label class="form-label">Receipt File (optional)</label>
                    <input type="text" name="receiptFile" class="form-control" placeholder="receipt.pdf" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('addExpenseModal').classList.remove('active')">Cancel</button>
                <button type="submit" class="btn btn-primary">Create Expense</button>
            </div>
        </form>
    </div>
</div>
