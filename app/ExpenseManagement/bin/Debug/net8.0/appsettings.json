{
  "_comment": "For local development, change Authentication in connection string to 'Authentication=Active Directory Default' to use az login",
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:<SQL_SERVER_FQDN>,1433;Database=Northwind;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "ManagedIdentityClientId": "<MANAGED_IDENTITY_CLIENT_ID>",
  "OpenAI": {
    "Endpoint": "<OPENAI_ENDPOINT>",
