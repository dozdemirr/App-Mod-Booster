  },
  "Search": {
    "Endpoint": "<SEARCH_ENDPOINT>"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
