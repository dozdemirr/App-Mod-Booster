@page
@model ExpenseMgmt.Pages.Expenses.AddModel
@{
    ViewData["Title"] = "Add Expense";
}

<div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6">

        <div class="mb-4">
            <h1 class="h2 fw-bold text-primary"><i class="bi bi-plus-circle me-2"></i>Add Expense</h1>
            <p class="text-muted">Submit a new expense claim. It will be saved as a Draft until you submit it for approval.</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.ErrorMessage
            </div>
        }

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label for="userId" class="form-label fw-semibold">Employee</label>
                        <select id="userId" name="userId" class="form-select form-select-lg" required>
                            <option value="">— Select Employee —</option>
                            @foreach (var user in Model.Users)
                            {
                                <option value="@user.UserId">@user.UserName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label for="amountGBP" class="form-label fw-semibold">Amount (£)</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text">£</span>
                            <input type="number" id="amountGBP" name="amountGBP" class="form-control"
                                   step="0.01" min="0.01" placeholder="0.00" required
                                   value="@Model.Input.AmountGBP" />
                        </div>
                        <div class="form-text">Enter the amount in pounds (e.g., 12.50 for £12.50)</div>
                    </div>

                    <div class="mb-4">
                        <label for="expenseDate" class="form-label fw-semibold">Date</label>
                        <input type="date" id="expenseDate" name="expenseDate" class="form-control form-control-lg"
                               value="@Model.Input.ExpenseDate.ToString("yyyy-MM-dd")" required max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="mb-4">
                        <label for="categoryId" class="form-label fw-semibold">Category</label>
                        <select id="categoryId" name="categoryId" class="form-select form-select-lg" required>
                            <option value="">— Select Category —</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.CategoryId" selected="@(Model.Input.CategoryId == cat.CategoryId ? "selected" : null)">
                                    @cat.CategoryName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label for="description" class="form-label fw-semibold">Description</label>
                        <textarea id="description" name="description" class="form-control"
                                  rows="3" placeholder="Describe the expense (e.g., Taxi from airport to client site)...">@Model.Input.Description</textarea>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                            <i class="bi bi-floppy me-2"></i>Save as Draft
                        </button>
                        <a asp-page="/Expenses/Index" class="btn btn-outline-secondary btn-lg">
                            <i class="bi bi-x-circle me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="mt-3 text-muted small">
            <i class="bi bi-info-circle me-1"></i>
            Saved expenses start as <strong>Draft</strong>. Go to <a asp-page="/Expenses/Index">My Expenses</a> to submit them for manager approval.
        </div>
    </div>
</div>
