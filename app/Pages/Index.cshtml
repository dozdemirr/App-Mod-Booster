@page
@model ExpenseMgmt.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col">
        <h1 class="h2 fw-bold text-primary"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h1>
        <p class="text-muted">Welcome to the Expense Management System</p>
    </div>
</div>

@* Summary Cards *@
<div class="row g-4 mb-5">
    @foreach (var item in Model.Summary)
    {
        var (icon, color) = item.StatusName switch {
            "Draft"     => ("bi-pencil-square", "secondary"),
            "Submitted" => ("bi-send", "warning"),
            "Approved"  => ("bi-check-circle", "success"),
            "Rejected"  => ("bi-x-circle", "danger"),
            _           => ("bi-circle", "primary")
        };
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-@color bg-opacity-10 p-3 me-3">
                            <i class="bi @icon text-@color fs-4"></i>
                        </div>
                        <div>
                            <div class="text-muted small">@item.StatusName</div>
                            <div class="fw-bold fs-4">@item.ExpenseCount</div>
                        </div>
                    </div>
                    <div class="text-@color fw-semibold">£@item.TotalAmountGBP.ToString("N2")</div>
                    <div class="text-muted small">total expenses</div>
                </div>
            </div>
        </div>
    }
</div>

@* Quick Actions *@
<div class="row g-4 mb-5">
    <div class="col-12">
        <h2 class="h5 fw-semibold mb-3">Quick Actions</h2>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a asp-page="/Expenses/Add" class="card border-0 shadow-sm text-decoration-none h-100 card-hover">
            <div class="card-body text-center py-4">
                <i class="bi bi-plus-circle-fill text-primary fs-1 mb-3 d-block"></i>
                <h5 class="fw-semibold mb-1">Add Expense</h5>
                <p class="text-muted small mb-0">Submit a new expense claim</p>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a asp-page="/Expenses/Index" class="card border-0 shadow-sm text-decoration-none h-100 card-hover">
            <div class="card-body text-center py-4">
                <i class="bi bi-list-ul text-success fs-1 mb-3 d-block"></i>
                <h5 class="fw-semibold mb-1">My Expenses</h5>
                <p class="text-muted small mb-0">View and manage your expenses</p>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a asp-page="/Approve/Index" class="card border-0 shadow-sm text-decoration-none h-100 card-hover">
            <div class="card-body text-center py-4">
                <i class="bi bi-check2-circle text-warning fs-1 mb-3 d-block"></i>
                <h5 class="fw-semibold mb-1">Approve Expenses</h5>
                <p class="text-muted small mb-0">Review pending expense claims</p>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a href="/chatui/index.html" target="_blank" class="card border-0 shadow-sm text-decoration-none h-100 card-hover">
            <div class="card-body text-center py-4">
                <i class="bi bi-chat-dots text-info fs-1 mb-3 d-block"></i>
                <h5 class="fw-semibold mb-1">AI Chat</h5>
                <p class="text-muted small mb-0">Ask questions in natural language</p>
            </div>
        </a>
    </div>
</div>

@* Recent Expenses *@
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
        <h2 class="h6 fw-semibold mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>Recent Expenses</h2>
        <a asp-page="/Expenses/Index" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Category</th>
                        <th>Description</th>
                        <th class="text-end">Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var exp in Model.RecentExpenses)
                    {
                        <tr>
                            <td>@exp.ExpenseDate.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge bg-light text-dark border">@exp.CategoryName</span></td>
                            <td class="text-truncate" style="max-width:200px">@exp.Description</td>
                            <td class="text-end fw-semibold">£@exp.AmountGBP.ToString("N2")</td>
                            <td>@Html.Raw(GetStatusBadge(exp.StatusName))</td>
                        </tr>
                    }
                    @if (!Model.RecentExpenses.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-4 d-block mb-2"></i>No expenses yet. <a asp-page="/Expenses/Add">Add your first expense</a>.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@functions {
    string GetStatusBadge(string status) => status switch {
        "Draft"     => "<span class=\"badge bg-secondary\">Draft</span>",
        "Submitted" => "<span class=\"badge bg-warning text-dark\">Submitted</span>",
        "Approved"  => "<span class=\"badge bg-success\">Approved</span>",
        "Rejected"  => "<span class=\"badge bg-danger\">Rejected</span>",
        _           => $"<span class=\"badge bg-light text-dark\">{status}</span>"
    };
}
