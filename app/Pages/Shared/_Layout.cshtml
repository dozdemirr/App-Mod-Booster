<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Expense Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/Index">
                <i class="bi bi-receipt-cutoff me-2"></i>ExpenseTrack
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Index"><i class="bi bi-house me-1"></i>Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Expenses/Index"><i class="bi bi-list-ul me-1"></i>My Expenses</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Expenses/Add"><i class="bi bi-plus-circle me-1"></i>Add Expense</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Approve/Index"><i class="bi bi-check2-circle me-1"></i>Approve</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/chatui/index.html" target="_blank"><i class="bi bi-chat-dots me-1"></i>AI Chat</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/swagger" target="_blank"><i class="bi bi-braces me-1"></i>API Docs</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    @* Database error alert bar - shown when DB is unavailable *@
    @if (ViewData["DbError"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show mb-0 rounded-0" role="alert" style="border-left: 4px solid #ff9800;">
            <strong><i class="bi bi-exclamation-triangle-fill me-2"></i>Database Connection Issue</strong>
            Showing demo data. @ViewData["DbError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <main class="container-fluid py-4">
        @RenderBody()
    </main>

    <footer class="footer mt-auto py-3 bg-light border-top">
        <div class="container-fluid text-center text-muted small">
            <span>Expense Management System &mdash; Modernised with Azure &amp; .NET 8</span>
            <span class="ms-3">
                <a href="/swagger" class="text-muted text-decoration-none"><i class="bi bi-braces me-1"></i>API Docs</a>
            </span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
