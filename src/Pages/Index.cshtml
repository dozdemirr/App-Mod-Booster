@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card bg-indigo">
            <div class="stat-value">@Model.TotalExpenses</div>
            <div class="stat-label">Total Expenses</div>
            <div class="stat-icon"><i class="bi bi-receipt"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card bg-amber">
            <div class="stat-value">@Model.SubmittedExpenses</div>
            <div class="stat-label">Pending Review</div>
            <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card bg-emerald">
            <div class="stat-value">@Model.ApprovedExpenses</div>
            <div class="stat-label">Approved</div>
            <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card bg-rose">
            <div class="stat-value">£@Model.TotalAmountGBP.ToString("N2")</div>
            <div class="stat-label">Total Value</div>
            <div class="stat-icon"><i class="bi bi-currency-pound"></i></div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-body d-flex gap-2 flex-wrap">
                <a asp-page="/Expenses/Create" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i>New Expense
                </a>
                <a asp-page="/Expenses/Index" class="btn btn-outline-secondary">
                    <i class="bi bi-list-ul me-1"></i>All Expenses
                </a>
                <a asp-page="/Expenses/Index" asp-route-status="Submitted" class="btn btn-outline-warning">
                    <i class="bi bi-hourglass me-1"></i>Pending Review
                </a>
                <a asp-page="/Chat" class="btn btn-outline-primary">
                    <i class="bi bi-chat-dots me-1"></i>AI Assistant
                </a>
                <a href="/swagger" target="_blank" class="btn btn-outline-secondary">
                    <i class="bi bi-code-slash me-1"></i>API Docs
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Recent Expenses -->
<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-clock-history me-2"></i>Recent Expenses</h6>
        <a asp-page="/Expenses/Index" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>User</th>
                        <th>Category</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var expense in Model.RecentExpenses)
                    {
                        <tr>
                            <td class="text-muted">#@expense.ExpenseId</td>
                            <td><span class="fw-medium">@expense.UserName</span></td>
                            <td>@expense.CategoryName</td>
                            <td class="fw-semibold">£@expense.AmountGBP.ToString("N2")</td>
                            <td class="text-muted">@expense.ExpenseDate.ToString("dd MMM yyyy")</td>
                            <td>
                                <span class="badge badge-@expense.StatusName.ToLower()">@expense.StatusName</span>
                            </td>
                            <td>
                                <a asp-page="/Expenses/Detail" asp-route-id="@expense.ExpenseId" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
