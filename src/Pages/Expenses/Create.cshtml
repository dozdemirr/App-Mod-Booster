@page
@model ExpenseApp.Pages.Expenses.CreateModel
@{ViewData["Title"] = "New Expense";}
<div class="row justify-content-center">
<div class="col-md-7">
<div class="card">
    <div class="card-header bg-white py-3"><h6 class="mb-0 fw-semibold"><i class="bi bi-plus-circle me-2"></i>Create New Expense</h6></div>
    <div class="card-body">
        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-medium">Employee</label>
                <select asp-for="Input.UserId" asp-items="Model.UserItems" class="form-select"></select>
            </div>
            <div class="row mb-3">
                <div class="col">
                    <label class="form-label fw-medium">Category</label>
                    <select asp-for="Input.CategoryId" asp-items="Model.CategoryItems" class="form-select"></select>
                </div>
                <div class="col">
                    <label class="form-label fw-medium">Amount (£)</label>
                    <div class="input-group">
                        <span class="input-group-text">£</span>
                        <input asp-for="Input.AmountGBP" type="number" step="0.01" min="0.01" class="form-control" placeholder="0.00" />
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label fw-medium">Expense Date</label>
                <input asp-for="Input.ExpenseDate" type="date" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-medium">Description</label>
                <textarea asp-for="Input.Description" class="form-control" rows="3" placeholder="Describe the expense..."></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save as Draft</button>
                <a asp-page="/Expenses/Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div>
</div>
